{
  "polygons": [
    {
      "type": "Building",
      "path": "data/cranfield_buildings.geojson",
      "height_attribute": "height",
      "floor_attribute": "building:levels",
      "floor_height": 3.0
    },
    {
      "type": "SurfaceLayer",
      "path": "data/cranfield_runway.geojson",
      "layer_name": "Runway"
    },
    {
      "type": "SurfaceLayer",
      "path": "data/cranfield_vegetation.geojson",
      "layer_name": "Vegetation"
    },
    {
      "type": "SurfaceLayer",
      "path": "data/cranfield_water.geojson",
      "layer_name": "Water"
    }
  ],
  "reconstruction_regions": [
    {
      "influence_region": 600,
      "lod": "1.2"
    },
    {
      "influence_region": 1500,
      "lod": "1.2"
    }
  ],

  "point_of_interest": [494916, 242440],
  "domain_bnd":        null,
  "top_height":        300,

  "bnd_type_bpg":      "Rectangle",
  "bpg_blockage_ratio": false,
  "flow_direction":    [0.553, 0.833],
  "buffer_region":     -20,
  "reconstruct_boundaries": true,

  "flat_terrain": true,

  "min_height": 3,
  "reconstruct_failed": true,

  "building_percentile": 90,
  "edge_max_len": 5,

  "output_file_name":  "Cranfield_Runway",
  "output_format":     "obj",
  "output_separately": true,

  "output_log": true,
  "log_file": "logFile.log"
}
